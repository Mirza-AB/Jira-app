# Database (optional: defaults in application.properties)
DB_URL=jdbc:postgresql://localhost:5432/jiraclone
DB_USERNAME=postgres
DB_PASSWORD=your-db-password

# JWT (required for app to start)
# Use a long random string or base64 (min 32 chars). Generate with: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-at-least-32-chars

# JWT expiration (optional: defaults in application.properties)
JWT_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION_MS=86400000

# Rate limiting (optional)
RATE_LIMIT_REQUESTS=5
RATE_LIMIT_MINUTES=1
